  "troubleshooting": {
    "_info": "Common issues and solutions from community",
    "black_screen": {
      "description": "Black screen on launch",
      "solutions": [
        "Delete Engine.ini and let game regenerate",
        "Check r.MobileContentScaleFactor not set too high",
        "Verify Vulkan driver updated"
      ],
      "source": "Steam Community"
    },
    "low_fps": {
      "description": "Lower than expected FPS",
      "solutions": [
        "Check if thermal throttling (r.Kuro.AutoCoolEnable=1)",
        "Verify FPS cap in-game settings",
        "Disable unnecessary post-processing"
      ],
      "source": "Reddit"
    },
    "stuttering": {
      "description": "Stutter during gameplay",
      "solutions": [
        "Enable r.ShaderPipelineCache.Enabled=1",
        "Increase r.Streaming.PoolSize",
        "Check for GPU OOM in log"
      ],
      "source": "Multiple sources"
    },
    "white_artifacts": {
      "description": "White spots in dark areas/ caves",
      "solutions": [
        "Enable r.HZBOcclusion=1",
        "Check shader cache is building"
      ],
      "source": "Community"
    }
  },
