  "forbidden_cvars": {
    "_info": "CVars that cause issues, crashes, or are blocked by the game",
    "mandatory": {
      "fx.KuroUseGPUParticles": {
        "reason": "GPU particle crash - causes crashes on all GPUs",
        "fix": "Always set to 0",
        "severity": "critical"
      },
      "Niagara.GPUDrawIndirectArgsBufferSlack": {
        "reason": "Niagara crash buffer - must be set to prevent crashes",
        "fix": "Always set to 4096",
        "severity": "critical"
      }
    },
    "forbidden": {
      "r.FidelityFX.FSR.RCAS.Enabled": {
        "reason": "Causes visual artifacts + crash on some GPUs",
        "fix": "Remove entirely - game uses its own upscaler",
        "source": "AlteriaX/WuWa-Configs"
      },
      "r.TemporalAA.Sharpness": {
        "reason": "Causes visual artifacts",
        "fix": "Remove - not needed with game upscaler",
        "source": "Reddit community"
      },
      "r.Mobile.SSAO": {
        "reason": "Forbidden by game engine - causes issues",
        "fix": "Remove from config",
        "source": "Arglax"
      },
      "r.Mobile.EnableVoidGT": {
        "reason": "Causes OOM on low/mid GPU",
        "fix": "Keep disabled on mobile",
        "source": "Reddit"
      },
      "r.DefaultFeature.LensFlare": {
        "reason": "Causes lens flare issues on some GPUs",
        "fix": "Keep at default (0)",
        "source": "Community"
      }
    },
    "risky": {
      "r.Streaming.PoolSize": {
        "value": 2048,
        "reason": "High memory usage - may cause OOM on 8GB GPUs",
        "fix": "Stick to preset recommendations (500-1200)",
        "source": "Reddit VRAM thread"
      },
      "r.MobileContentScaleFactor": {
        "value": ">1.0",
        "reason": "Upscaling above native causes artifacts",
        "fix": "Use 0 for native, or preset values",
        "source": "Arglax"
      }
    }
  },
